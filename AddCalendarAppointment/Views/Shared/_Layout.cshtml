@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - Calendar</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
		<link rel="stylesheet" href="~/css/site.css" />
		<style>
			/* CSS cho Mini Calendar */
			.mini-calendar { font-size: 0.85rem; background: #fff; padding: 10px; }
			.mini-calendar table { width: 100%; text-align: center; border-collapse: separate; border-spacing: 0 2px; }
			.mini-calendar th { color: #70757a; font-weight: 500; padding-bottom: 10px; font-size: 11px; }
			.mini-calendar td { width: 32px; height: 32px; line-height: 32px; padding: 0; cursor: pointer; border-radius: 50%; transition: 0.2s; }

			/* Hiệu ứng hover cho các ngày trong tháng (không bao gồm ngày mờ) */
			.mini-calendar td:not(.text-muted):hover { background-color: #f1f3f4; }

			/* Ngày hiện tại: Xanh đậm */
			.mini-calendar .current-day { background-color: #1a73e8 !important; color: white !important; font-weight: bold; }

			/* Ngày đang chọn: Xanh nhạt */
			.mini-calendar td.selected-day { background-color: #d2e3fc !important; color: #1a73e8 !important; font-weight: bold; }

			/* Ngày tháng khác: Chỉ làm mờ chữ, tuyệt đối không màu nền */
			.mini-calendar .text-muted { color: #dadce0 !important; cursor: default; background: none !important; }
			.mini-calendar .text-muted:hover { background: none !important; }

			/* Ẩn dấu mũi tên mặc định của dropdown trên avatar */
			.no-caret::after {
				display: none !important;
			}

			.dropdown-item:active {
				background-color: #f8f9fa;
				color: #dc3545;
			}
		</style>
	</head>
	<body>
		<header class="app-header">
			<i class="fa-solid fa-bars menu-icon" id="btnToggleSidebar" style="cursor:pointer"></i>
			<div class="brand-logo">
				<img src="https://d1csarkz8obe9u.cloudfront.net/posterpreviews/calendar-clipart-logo-design-template-9a3d7bbcf620587d4b74313072040475_screen.jpg?ts=1611246431" alt="Logo" />
				<span>Calendar</span>
			</div>

			<div class="d-flex align-items-center ms-3">
				<button class="btn btn-outline-secondary btn-sm rounded-pill px-3 me-3" id="btn-today">Today</button>
				<i class="fa-solid fa-chevron-left ms-2 me-3" style="cursor:pointer" id="main-prev"></i>
				<i class="fa-solid fa-chevron-right me-3" style="cursor:pointer" id="main-next"></i>
				<h4 class="m-0 fs-5" id="main-month-title"></h4>
			</div>

		<div class="header-actions ms-auto d-flex align-items-center">
			<!-- NÚT CHUÔNG THÔNG BÁO -->
			<div class="dropdown mx-2">
				<button class="btn btn-light rounded-circle position-relative p-2 d-flex align-items-center justify-content-center" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: none; width: 36px; height: 36px;">
					<i class="fa-regular fa-bell fs-5 text-secondary"></i>
					<span id="notification-badge" class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle d-none">
						<span class="visually-hidden">New alerts</span>
					</span>
				</button>
				<ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-0" aria-labelledby="notificationDropdown" style="width: 350px; max-height: 400px; overflow-y: auto;" id="notification-list-container">
					<li class="p-3 text-center text-muted">No notifications</li>
				</ul>
			</div>

            <div class="view-dropdown mx-2">
                <select id="viewSelector" class="form-select form-select-sm border-secondary rounded-pill">
                    <option value="1">Day</option>
                    <option value="7" selected>Week</option>
                    <option value="30">Month</option>
                    <option value="365">Year</option>
                    <option disabled>──────</option>
                    <option value="3">3 Days (Custom)</option>
                    <option value="14">2 Weeks (Custom)</option>
                </select>
            </div>
			@{
				// Lấy Email từ Session, nếu chưa có thì để mặc định là "User"
				var userEmail = Context.Session.GetString("UserEmail") ?? "U";
				var firstLetter = userEmail.Substring(0, 1).ToUpper();
			}

			<!-- NÚT AVATAR VÀ DROPDOWN ĐĂNG XUẤT -->
			<div class="dropdown ms-2">
				<div class="dropdown-toggle no-caret" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer">
					<!-- Sử dụng API ui-avatars để tạo hình tròn chứa chữ cái đầu -->
					<img src="https://ui-avatars.com/api/?name=@firstLetter&background=0D8ABC&color=fff&rounded=true"
						 class="rounded-circle border" width="32" height="32" alt="Avatar" />
				</div>
				<ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userMenu">
					<li class="px-3 py-2 small text-muted border-bottom text-truncate" style="max-width: 200px;">
						@userEmail
					</li>
					<!-- THÊM NÚT ĐỔI MẬT KHẨU Ở ĐÂY -->
					<li>
						<a class="dropdown-item mt-1" href="#" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
							<i class="fa-solid fa-key me-2 small text-secondary"></i> Đổi mật khẩu
						</a>
					</li>

					<!-- ĐƯỜNG KẺ NGANG ĐỂ TÁCH BIỆT NÚT ĐĂNG XUẤT -->
					<li><hr class="dropdown-divider"></li>
					<li>
						<a class="dropdown-item text-danger mt-1" asp-controller="Account" asp-action="Logout">
							<i class="fa-solid fa-right-from-bracket me-2 small"></i> Đăng xuất
						</a>
					</li>
				</ul>
			</div>
        </div>
    </header>

		<div class="app-body">
			<aside class="app-sidebar" id="sidebar">
				@{
    // KIỂM TRA ĐƯỜNG DẪN HIỆN TẠI
    bool isTeamPage = Context.Request.Path.Value != null 
        && Context.Request.Path.Value.Contains("/Team/Manage", StringComparison.OrdinalIgnoreCase);
}

<div class="create-button-container">
    <button 
        id="btn-create-event"
        class="btn btn-light rounded-pill shadow-sm d-flex align-items-center px-3 py-2"
        type="button"
        @(isTeamPage ? "style=opacity:0.5; cursor:not-allowed; pointer-events:none;" : "")
    >
        <i class="fa-solid fa-plus me-2 fs-4" style="color: #1a73e8;"></i>
        <span class="fs-5" style="color: #3c4043; font-weight: 500;">Create</span>
    </button>
</div>

			<!-- NÚT ĐIỀU HƯỚNG (MY TEAMS / BACK TO CALENDAR) -->
			<div class="sidebar-section mt-4">
				@if (isTeamPage)
				{
					// Nút Back to Calendar (Chỉ hiện ở trang Team)
					<button class="btn btn-light w-100 text-start border-0 shadow-sm" onclick="window.location.href='/Home/Index'" style="border-radius: 20px; padding: 10px 15px; background: #fff;">
						<i class="fa-solid fa-arrow-left me-2 text-primary"></i>
						<span class="fw-bold" style="color: #3c4043; font-size: 0.9rem;">Back to Calendar</span>
					</button>
				}
				else
				{
					// Nút My Teams (Chỉ hiện ở trang Calendar)
					<button class="btn btn-light w-100 text-start border-0 shadow-sm" onclick="window.location.href='/Team/Manage'" style="border-radius: 20px; padding: 10px 15px; background: #fff;">
						<i class="fa-solid fa-users me-2 text-primary"></i>
						<span class="fw-bold" style="color: #3c4043; font-size: 0.9rem;">My teams</span>
					</button>
				}
			</div>

			<!-- MINI CALENDAR (Giữ nguyên của bạn) -->
			<div class="sidebar-section mini-calendar mt-4">
				<div class="d-flex justify-content-between align-items-center mb-2 px-2">
					<span class="fw-bold" id="mini-month-title"></span>
					<div>
						<button class="btn btn-light btn-sm rounded-circle border-0" id="mini-prev">
							<i class="fa-solid fa-chevron-left"></i>
						</button>
						<button class="btn btn-light btn-sm rounded-circle border-0 ms-1 me-3" id="mini-next">
							<i class="fa-solid fa-chevron-right"></i>
						</button>
					</div>
				</div>
				<table>
					<thead>
						<tr>
							<th class="text-danger">S</th>
							<th>M</th>
							<th>T</th>
							<th>W</th>
							<th>T</th>
							<th>F</th>
							<th>S</th>
						</tr>
					</thead>
					<tbody id="mini-calendar-body"></tbody>
				</table>
			</div>

			<!-- MY CALENDARS LIST (Giữ nguyên của bạn) -->
			<div class="sidebar-section mt-4">
				<h6 class="text-muted mb-2" style="font-size: 13px; font-weight: bold;">My calendars</h6>
				<!-- Danh sách lịch (kèm ô đổi tên) sẽ được JS tự động đổ vào đây -->
				<div id="my-calendars-list"></div>
			</div>
		</aside>

		<main class="calendar-main">
			@RenderBody()
		</main>
	</div>

		<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Thêm dòng này để nhúng file calendar.js -->
    <script src="~/js/calendar.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)

	<!-- ================= MODAL ĐỔI MẬT KHẨU ================= -->
	<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="changePasswordLabel">Đổi Mật Khẩu</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<form id="changePasswordForm">
						<div class="mb-3">
							<label class="form-label text-muted small fw-bold">Mật khẩu hiện tại</label>
							<input type="password" class="form-control" id="oldPassword" required>
						</div>
						<div class="mb-3">
							<label class="form-label text-muted small fw-bold">Mật khẩu mới</label>
							<input type="password" class="form-control" id="newPassword" required>
						</div>
						<div class="mb-3">
							<label class="form-label text-muted small fw-bold">Xác nhận mật khẩu mới</label>
							<input type="password" class="form-control" id="confirmPassword" required>
						</div>

						<!-- Chỗ để hiển thị thông báo lỗi hoặc thành công -->
						<div id="changePasswordAlert" class="alert d-none" role="alert"></div>
					</form>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
					<button type="button" class="btn btn-primary" id="btnSubmitChangePassword">Cập nhật mật khẩu</button>
				</div>
			</div>
		</div>
	</div>

	<div class="modal fade" id="conflictSelectionModal" tabindex="-1" aria-hidden="true" style="z-index: 1075;">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title text-primary"><i class="fas fa-layer-group me-2"></i>Chọn nhóm để tham gia</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
				</div>
				<div class="modal-body">
					<p class="text-muted small">Phát hiện các cuộc họp nhóm trùng tên đang diễn ra trong khung giờ này. Vui lòng chọn cuộc họp bạn muốn tham gia:</p>
					<div id="conflict-list-container" class="list-group mb-3">
						</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
					<button type="button" class="btn btn-primary" id="btn-confirm-join-conflict">Xác nhận tham gia</button>
				</div>
			</div>
		</div>
	</div>

	<!-- ================= JAVASCRIPT XỬ LÝ ĐỔI MẬT KHẨU ================= -->
	<script>
		document.getElementById('btnSubmitChangePassword').addEventListener('click', function () {
		// Lấy dữ liệu từ các ô input
		var oldP = document.getElementById('oldPassword').value;
		var newP = document.getElementById('newPassword').value;
		var confP = document.getElementById('confirmPassword').value;
		var alertBox = document.getElementById('changePasswordAlert');

		// Bỏ ẩn thông báo
		alertBox.classList.remove('d-none');

		// Validate cơ bản
		if (!oldP || !newP || !confP) {
		alertBox.className = 'alert alert-danger mt-2';
		alertBox.innerText = 'Vui lòng điền đầy đủ thông tin!';
		return;
		}

		// Đóng gói dữ liệu gửi lên server
		var formData = new FormData();
		formData.append('oldPassword', oldP);
		formData.append('newPassword', newP);
		formData.append('confirmPassword', confP);

		// Gọi API lên hàm ChangePassword trong AccountController
		fetch('/Account/ChangePassword', {
		method: 'POST',
		body: formData
		})
		.then(response => response.json())
		.then(data => {
		if (data.success) {
		// Hiển thị màu xanh lá báo thành công
		alertBox.className = 'alert alert-success mt-2';
		alertBox.innerText = data.message;

		// Xóa trống form
		document.getElementById('changePasswordForm').reset();

		// Tự động tắt bảng Modal sau 1.5 giây
		setTimeout(() => {
		var myModalEl = document.getElementById('changePasswordModal');
		var modal = bootstrap.Modal.getInstance(myModalEl);
		modal.hide();
		alertBox.classList.add('d-none'); // ẩn lại thông báo
		}, 1500);
		} else {
		// Hiển thị màu đỏ báo lỗi
		alertBox.className = 'alert alert-danger mt-2';
		alertBox.innerText = data.message;
		}
		})
		.catch(error => {
		console.error('Error:', error);
		alertBox.className = 'alert alert-danger mt-2';
		alertBox.innerText = 'Có lỗi xảy ra, vui lòng thử lại sau!';
		});
		});
	</script>

	<script>
		$(document).ready(function () {
			function loadNotifications() {
				$.ajax({
					url: '/api/Appointment/notifications',
					type: 'GET',
					success: function (data) {
						let unreadCount = data.filter(n => !n.isRead).length;
						
						// Cập nhật hiển thị chấm đỏ ở quả chuông
						if (unreadCount > 0) {
							$('#notification-badge').removeClass('d-none');
						} else {
							$('#notification-badge').addClass('d-none');
						}

						// Render danh sách
						let container = $('#notification-list-container');
						container.empty();

						if (data.length === 0) {
							container.append('<li class="p-3 text-center text-muted">Không có thông báo mới</li>');
							return;
						}

						data.forEach(n => {
							// CSS đậm nhạt cho tin chưa đọc/đã đọc
							let bgClass = n.isRead ? "bg-light text-muted" : "bg-white fw-bold";
							let dot = n.isRead ? "" : `<span class="text-primary ms-2"><i class="fa-solid fa-circle" style="font-size: 8px;"></i></span>`;
							
							container.append(`
								<li>
									<a class="dropdown-item py-2 border-bottom ${bgClass} notification-item" href="#" data-id="${n.id}">
										<div class="d-flex justify-content-between align-items-center">
											<span class="text-wrap" style="font-size: 0.9rem;">${n.message}</span>
											${dot}
										</div>
										<small class="${n.isRead ? 'text-muted' : 'text-primary'}" style="font-size: 0.75rem;">${n.timeStr}</small>
									</a>
								</li>
							`);
						});
					}
				});
			}

			// Chạy ngay khi tải trang web xong
			loadNotifications();

			// Bạn có thể bỏ comment dòng dưới nếu muốn tự động làm mới thông báo mỗi 1 phút
			setInterval(loadNotifications, 15000);

			// Xử lý khi user click vào 1 thông báo
			$(document).on('click', '.notification-item', function (e) {
				e.preventDefault(); 
				let notifId = $(this).data('id');
				
				$.ajax({
					url: '/api/Appointment/mark-read/' + notifId,
					type: 'POST',
					success: function () {
						// Tải lại danh sách để tự động xử lý đổi màu background và mất chấm đỏ
						loadNotifications();
					}
				});
			});
		});
	</script>

</body>
</html>
