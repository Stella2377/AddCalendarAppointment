@{
    ViewData["Title"] = "Calendar";
    // Giả lập Dữ liệu lấy từ Controller (Dựa trên Model UserSettings)
    // Nếu User chọn view "Week", ViewDays = 7. Nếu chọn custom "3 days", ViewDays = 3.
    int ViewDays = 7;

    DateTime today = DateTime.Today;
    DateTime startOfWeek = today.AddDays(-(int)today.DayOfWeek);
}

<style>
    :root {
        --col-count: @ViewDays;
    }
</style>

<div class="calendar-header-grid">
    <div class="time-header" style="font-size: 10px; color: #70757a; text-align: left; padding-left: 8px; margin-top: auto;">GMT+07</div>
    
    @for (int i = 0; i < ViewDays; i++)
    {
        DateTime currentDay = startOfWeek.AddDays(i);
        string activeClass = (currentDay.Date == DateTime.Today) ? "active" : ""; // Highlight ngày hôm nay
        
        <div class="day-header @activeClass">
            <div class="day-name">@currentDay.ToString("ddd").ToUpper()</div>
            <div class="day-num">@currentDay.Day</div>
        </div>
    }
</div>

<div class="calendar-body-scroll">
    <div class="calendar-grid">
        <div class="time-col">
            @for (int h = 1; h <= 23; h++)
            {
                string ampm = h < 12 ? "AM" : "PM";
                int displayHour = h <= 12 ? h : h - 12;
                <div class="time-slot"><span>@displayHour @ampm</span></div>
            }
        </div>

        @for (int i = 0; i < ViewDays; i++)
        {
            DateTime currentDay = startOfWeek.AddDays(i);

            <!-- Quan trọng: Thêm thuộc tính data-date để Javascript Kéo-Thả có thể lấy được ngày -->
            <div class="day-col" data-date="@currentDay.ToString("yyyy-MM-dd")">
                
                @if (Model != null)
                {
                    // Lọc ra các cuộc hẹn thuộc về ngày hiện tại của vòng lặp
                    // ... inside the Razor loop where appointments are filtered:
                    var todaysAppointments = ((IEnumerable<dynamic>)Model)
                        .Where(a => a.StartTime.Date == currentDay.Date)
                        .ToList();
                    
                    foreach (var app in todaysAppointments)
                    {
                        // Tính toán tọa độ Y (top) và chiều cao (height)
                        // Quy ước lưới: 1 giờ = 60px
                        int topPx = (app.StartTime.Hour * 60) + app.StartTime.Minute;
                        int durationMins = (int)(app.EndTime - app.StartTime).TotalMinutes;
                        int heightPx = durationMins > 0 ? durationMins : 60; // Mặc định cao 60px (1 tiếng) nếu lỗi thời gian

                        <!-- Thẻ này được gắn data-id để liên kết với các thao tác trong calendar.js -->
                        <div class="appointment-block"
                             data-id="@app.Id"
                             style="top: @(topPx)px; height: @(heightPx)px; background-color: #3f51b5;">
                            <div class="title">@app.Title</div>
                            <div class="time-loc">
                                @app.StartTime.ToString("h:mm tt") - @app.EndTime.ToString("h:mm tt")
                                @if (!string.IsNullOrEmpty(app.Location))
                                {
                                    <br />
                                    @app.Location
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>