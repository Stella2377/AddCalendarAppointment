@{
    ViewData["Title"] = "Calendar";
    // Thiết lập mặc định ban đầu
    int ViewDays = 7;
}

<style>
    :root {
        /* Biến này sẽ được cập nhật động bằng JS khi đổi View */
        --col-count: @ViewDays;
    }
</style>

<!-- HEADER LỊCH (Thứ, Ngày) -->
<div class="calendar-header-grid" id="main-header-grid">
    <div class="time-header" style="font-size: 10px; color: #70757a; text-align: left; padding-left: 8px; margin-top: auto;">GMT+07</div>
    
    <!-- JavaScript sẽ tự động render các .day-header vào đây -->
</div>

<!-- BODY LỊCH (Lưới giờ và Sự kiện) -->
<div class="calendar-body-scroll">
    <div class="calendar-grid" id="main-calendar-grid">
        <!-- Cột hiển thị giờ (Cố định 24h) -->
        <div class="time-col">
            @for (int h = 0; h <= 23; h++)
            {
                string ampm;
                int displayHour;
                if (h == 0) { displayHour = 12; ampm = "AM"; }
                else if (h < 12) { displayHour = h; ampm = "AM"; }
                else if (h == 12) { displayHour = 12; ampm = "PM"; }
                else { displayHour = h - 12; ampm = "PM"; }

                <div class="time-slot"><span>@displayHour @ampm</span></div>
            }
        </div>

        <!-- JavaScript sẽ tự động render các .day-col vào đây -->
    </div>
</div>

<!-- KHUNG CHỨA KẾT QUẢ TÌM KIẾM (Mặc định ẩn) -->
<div id="search-results-container" style="display: none; flex: 1; overflow-y: auto; background: white; z-index: 100;">
    <div id="search-results-list" class="pb-5">
        <!-- JS sẽ nhét các dòng kết quả vào đây -->
    </div>
</div>

<!-- POPOVER TẠO SỰ KIỆN MỚI -->
<div id="event-popover" class="bg-white border" style="display:none; position: absolute; z-index: 1050; width: 440px;">
    
    <!-- Thanh kéo thả (Drag Handle) -->
    <div id="popover-header" class="d-flex justify-content-between align-items-center px-3 py-2">
        <i class="bi bi-grip-horizontal text-muted fs-5"></i>
        <button type="button" class="btn-close" id="btn-close-popover"></button>
    </div>

    <!-- Nội dung form có Scroll -->
    <div class="popover-body-scroll p-3 pt-0">
        <!-- Tiêu đề & Nút chọn loại -->
        <div class="mb-3 px-3">
            <input type="text" id="popover-title" class="form-control fs-4 border-0 border-bottom rounded-0 px-0 shadow-none mb-3" placeholder="Add title" style="border-color: #1a73e8 !important;" autofocus>
        </div>

        <!-- Thời gian -->
        <div class="d-flex align-items-start mb-3 px-3">
            <div class="me-3 mt-1 text-muted"><i class="bi bi-clock fs-5"></i></div>
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap time-input-group">
                    <input type="date" id="popover-start-date" class="form-control form-control-sm border-0 bg-light">
                    <input type="time" id="popover-start-time" class="form-control form-control-sm border-0 bg-light">
                    <span>-</span>
                    <input type="time" id="popover-end-time" class="form-control form-control-sm border-0 bg-light">
                </div>
                <small class="text-muted">Time zone • Does not repeat</small>
            </div>
        </div>

        <!-- Guests -->
        <div class="d-flex align-items-start mb-3 px-3">
            <div class="me-3 mt-1 text-muted"><i class="bi bi-people fs-5"></i></div>
            <div class="flex-grow-1">
                <!-- Nơi chứa các tag Guest đã thêm -->
                <div id="guest-badges-container" class="mb-1 d-flex flex-wrap gap-1"></div>
                
                <!-- Ô nhập email có gợi ý -->
                <input type="email" id="popover-guests" class="form-control form-control-sm border-0 bg-light" placeholder="Nhập Email và nhấn Enter" list="guest-suggestions">
                <datalist id="guest-suggestions"></datalist>
            </div>
        </div>

        <!-- Location & Description -->
        <div class="d-flex align-items-center mb-3 px-3">
            <div class="me-3 text-muted"><i class="bi bi-geo-alt fs-5"></i></div>
            <input type="text" id="popover-location" class="form-control form-control-sm border-0 bg-light" placeholder="Add location">
        </div>
        <div class="d-flex align-items-center mb-3 px-3">
            <div class="me-3 text-muted"><i class="bi bi-justify-left fs-5"></i></div>
            <input type="text" id="popover-description" class="form-control form-control-sm border-0 bg-light" placeholder="Add description">
        </div>

        <!-- Lịch & Thông báo -->
        <div class="d-flex align-items-start mb-2 px-3">
            <div class="me-3 mt-1 text-muted"><i class="bi bi-calendar2-event fs-5"></i></div>
            <div class="flex-grow-1">
                
                <!-- ĐÃ SỬA: Dropdown Chọn Lịch (Gộp chung Màu và Tên) -->
                <div class="d-flex gap-2 mb-2">
                    <select id="popover-color-select" class="form-select form-select-sm border-0 bg-light w-100" style="font-weight: 500;">
                        <!-- JS sẽ tự động lấy dữ liệu từ Sidebar đổ vào đây -->
                    </select>
                </div>
                
                <div class="d-flex gap-2 mb-3">
                    <select class="form-select form-select-sm border-0 bg-light w-auto text-muted"><option>Busy</option><option>Free</option></select>
                    <select id="popover-visibility" class="form-select form-select-sm border-0 bg-light w-auto text-muted">
                        <option value="0">Default visibility</option>
                        <option value="1">Public</option>
                        <option value="2">Private</option>
                    </select>
                </div>

                <!-- Container chứa danh sách Team, mặc định ẩn (d-none) -->
                <div id="team-selection-container" class="mt-2 d-none">
                    <label class="small text-muted fw-bold">Chia sẻ với Team (Bạn :</label>
                    <div id="team-checkbox-list" class="d-flex flex-wrap gap-2 mt-1" style="max-height: 100px; overflow-y: auto;">
                        <!-- Javascript sẽ tự động đổ các checkbox vào đây -->
                    </div>
                </div>

                <!-- Danh sách Notification -->
                <div id="notification-list">
                    <div class="d-flex gap-2 mb-2 notification-item align-items-center">
                        <i class="bi bi-bell text-muted me-1"></i>
                        <select class="form-select form-select-sm border-0 bg-light w-auto text-muted">
                            <option>30 minutes before</option>
                            <option>10 minutes before</option>
                            <option>1 hour before</option>
                        </select>
                        <button type="button" class="btn btn-sm text-muted btn-remove-notify"><i class="bi bi-x"></i></button>
                    </div>
                </div>
                <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 mt-1" id="btn-add-notification">Add notification</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="d-flex justify-content-end align-items-center px-3 py-3 border-top">
        <button class="btn btn-light btn-sm me-2 text-primary fw-bold bg-transparent">More options</button>
        <button id="btn-save-event" class="btn btn-primary px-4 rounded-pill">Save</button>
    </div>
</div>

<!-- POPOVER CHI TIẾT SỰ KIỆN (DETAIL VIEW) -->
<div id="event-detail-popover" class="bg-white border" style="display:none; position: absolute; z-index: 1040; width: 360px; box-shadow: 0 12px 24px rgba(0,0,0,0.15); border-radius: 12px; overflow: hidden;">
    
    <!-- Header Tools -->
    <div class="d-flex justify-content-end align-items-center p-2 bg-light" style="border-bottom: 1px solid #f1f3f4;">
        <button class="btn btn-sm text-muted px-2 border-0 shadow-none"><i class="fas fa-pen"></i></button>
        <button id="btn-delete-event" class="btn btn-sm text-muted px-2 border-0 shadow-none"><i class="fas fa-trash"></i></button>
        <button class="btn btn-sm text-muted px-2 border-0 shadow-none"><i class="fas fa-envelope"></i></button>
        <button class="btn btn-sm text-muted px-2 border-0 shadow-none"><i class="fas fa-ellipsis-v"></i></button>
        <button id="btn-close-detail" class="btn btn-sm text-muted px-2 border-0 shadow-none"><i class="fas fa-times"></i></button>
    </div>

    <!-- Body Information -->
    <div class="p-3">
        <!-- Title & Time -->
        <div class="d-flex align-items-start mb-3">
            <div class="mt-1 me-3 detail-icon" style="width: 24px; text-align: center;">
                <div id="detail-color-dot" style="width: 14px; height: 14px; border-radius: 4px; background-color: #039be5; display: inline-block;"></div>
            </div>
            <div>
                <h4 id="detail-title" class="mb-1" style="font-size: 18px; color: #3c4043;">(No title)</h4>
                <div id="detail-time" style="font-size: 14px; color: #3c4043;"></div>
            </div>
        </div>

        <!-- Invite via link -->
        <div class="d-flex align-items-start mb-3">
            <div class="me-3 detail-icon" style="width: 24px;"></div>
            <button id="btn-invite-link" class="btn btn-outline-secondary btn-sm rounded-pill px-3" style="color: #1a73e8; border-color: #dadce0; font-weight: 500;">
                <i class="fas fa-link me-1"></i> Invite via link
            </button>
        </div>

        <!-- Google Meet (Mock) - Ẩn mặc định -->
        <div id="detail-meet-row" class="d-none align-items-start mb-3">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-video fs-5"></i></div>
            <div>
                <div style="color: #1a73e8; font-size: 14px; font-weight: 500;">Join with Google Meet</div>
                <div style="color: #5f6368; font-size: 13px;">meet.google.com/mock-link</div>
            </div>
        </div>

        <!-- Location (Ẩn mặc định) -->
        <div id="detail-location-row" class="d-none align-items-start mb-3">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-map-marker-alt fs-5"></i></div>
            <div id="detail-location" style="font-size: 14px; color: #3c4043; padding-top: 2px;"></div>
        </div>

        <!-- Guests (Ẩn mặc định) -->
        <div id="detail-guests-row" class="d-none align-items-start mb-3">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-users fs-5"></i></div>
            <div class="w-100">
                <div id="detail-guest-count" style="font-size: 14px; color: #3c4043; font-weight: 500;"></div>
                <div id="detail-guest-list" class="mt-2">
                    <!-- JS sẽ đổ danh sách guest vào đây -->
                </div>
            </div>
        </div>

        <!-- Description (Ẩn mặc định) -->
        <div id="detail-description-row" class="d-none align-items-start mb-3">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-align-left fs-5"></i></div>
            <div id="detail-description" style="font-size: 14px; color: #3c4043; padding-top: 2px; white-space: pre-wrap;"></div>
        </div>

        <!-- Notification -->
        <div class="d-flex align-items-center mb-3">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-bell fs-5"></i></div>
            <div id="detail-notification" style="font-size: 14px; color: #3c4043;">30 minutes before</div>
        </div>

        <!-- Calendar Name -->
        <div class="d-flex align-items-center mb-1">
            <div class="me-3 detail-icon text-muted" style="width: 24px; text-align: center;"><i class="fas fa-calendar-alt fs-5"></i></div>
            <div id="detail-calendar-name" style="font-size: 14px; color: #3c4043;">Trương Thị Ngọc Huyền</div>
        </div>
    </div>
</div>

<!-- Modal Invite Via Link -->
<div class="modal fade" id="inviteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Share Meeting Link</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="text" id="meetingLinkUrl" class="form-control" readonly />
                    <button id="btnCopyLink" class="btn btn-primary">Copy</button>
                </div>
                <div class="permission-options mt-3">
                    <p class="mb-1 fw-bold">Quyền tham gia:</p>
                    <label class="d-block"><input type="radio" name="joinPermission" value="false" checked /> Bất kỳ ai có mã đều được tham gia</label>
                    <label class="d-block"><input type="radio" name="joinPermission" value="true" /> Phải được tôi phê duyệt</label>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Enter Code để Join -->
<div class="modal fade" id="joinMeetingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Join a Meeting</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="inputMeetingCode" class="form-control" placeholder="Nhập mã cuộc họp (VD: abc-defg-hij)" />
                <div id="overlapWarning" class="alert alert-warning mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnSubmitJoinCode" class="btn btn-primary">Join</button>
            </div>
        </div>
    </div>
</div>