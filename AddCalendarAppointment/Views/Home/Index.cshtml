@{
    ViewData["Title"] = "Calendar";
    // Thiết lập mặc định ban đầu
    int ViewDays = 7;
}

<style>
    :root {
        /* Biến này sẽ được cập nhật động bằng JS khi đổi View */
        --col-count: @ViewDays;
    }
</style>

<!-- Container bao quanh toàn bộ thanh search -->
<div class="search-wrapper">
    <div class="search-bar-container">
        <i class="bi bi-search search-icon"></i>
        <input type="text" id="main-search-input" placeholder="Search for events..." autocomplete="off">
        <button type="button" id="toggle-filter-btn" class="filter-toggle">
            <i class="bi bi-caret-down-fill"></i>
        </button>
    </div>

    <!-- Panel bộ lọc nâng cao (Mặc định ẩn) -->
    <div id="advanced-search-panel" class="advanced-panel shadow">
        <div class="filter-row">
            <label>Search in</label>
            <select id="filter-calendar-type">
                <option value="active">Active calendars</option>
                <option value="all">All calendars</option>
            </select>
        </div>
        <div class="filter-row">
            <label>What</label>
            <input type="text" id="filter-what" placeholder="Keywords contained in event">
        </div>
        <div class="filter-row">
            <label>Who</label>
            <input type="text" id="filter-who" placeholder="Enter a participant...">
        </div>
        <div class="filter-row">
            <label>Where</label>
            <input type="text" id="filter-where" placeholder="Enter a location...">
        </div>
        <div class="filter-row">
            <label>Doesn't have</label>
            <input type="text" id="filter-exclude" placeholder="Keywords not contained">
        </div>
        <div class="filter-row">
            <label>Date</label>
            <div class="date-range">
                <input type="date" id="filter-date-from">
                <span>to</span>
                <input type="date" id="filter-date-to">
            </div>
        </div>
        <div class="filter-footer">
            <button type="button" id="btn-reset-filter" class="btn-link">Reset</button>
            <button type="button" id="btn-submit-search" class="btn-search-blue">Search</button>
        </div>
    </div>
</div>

<!-- HEADER LỊCH (Thứ, Ngày) -->
<div class="calendar-header-grid" id="main-header-grid">
    <div class="time-header" style="font-size: 10px; color: #70757a; text-align: left; padding-left: 8px; margin-top: auto;">GMT+07</div>
    
    <!-- JavaScript sẽ tự động render các .day-header vào đây -->
</div>

<!-- BODY LỊCH (Lưới giờ và Sự kiện) -->
<div class="calendar-body-scroll">
    <div class="calendar-grid" id="main-calendar-grid">
        <!-- Cột hiển thị giờ (Cố định 24h) -->
        <div class="time-col">
            @for (int h = 0; h <= 23; h++)
            {
                string ampm;
                int displayHour;
                if (h == 0) { displayHour = 12; ampm = "AM"; }
                else if (h < 12) { displayHour = h; ampm = "AM"; }
                else if (h == 12) { displayHour = 12; ampm = "PM"; }
                else { displayHour = h - 12; ampm = "PM"; }

                <div class="time-slot"><span>@displayHour @ampm</span></div>
            }
        </div>

        <!-- JavaScript sẽ tự động render các .day-col vào đây -->
    </div>
</div>

<!-- POPOVER TẠO SỰ KIỆN MỚI GIỐNG GOOGLE CALENDAR -->
<div id="event-popover" class="shadow-lg rounded bg-white p-3 border" style="display:none; position: absolute; z-index: 1050; width: 420px; box-shadow: 0 8px 24px rgba(0,0,0,0.15);">
    
    <!-- Nút Đóng -->
    <div class="d-flex justify-content-end mb-1">
        <button type="button" class="btn-close" id="btn-close-popover"></button>
    </div>

    <!-- Tiêu đề & Loại sự kiện -->
    <div class="mb-3 px-3">
        <input type="text" id="popover-title" class="form-control fs-5 border-0 border-bottom rounded-0 px-0 shadow-none mb-2" placeholder="Add title" style="border-color: #1a73e8 !important;" autofocus>
    </div>

    <!-- Thời gian -->
    <div class="d-flex align-items-start mb-3 px-3">
        <div class="me-3 mt-1 text-muted"><i class="bi bi-clock fs-5"></i></div>
        <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-1">
                <input type="date" id="popover-start-date" class="form-control form-control-sm border-0 bg-light w-auto">
                <input type="time" id="popover-start-time" class="form-control form-control-sm border-0 bg-light w-auto">
                <span>-</span>
                <input type="time" id="popover-end-time" class="form-control form-control-sm border-0 bg-light w-auto">
            </div>
            <small class="text-muted">Time zone • Does not repeat</small>
        </div>
    </div>

    <!-- Guests -->
    <div class="d-flex align-items-center mb-3 px-3">
        <div class="me-3 text-muted"><i class="bi bi-people fs-5"></i></div>
        <input type="text" id="popover-guests" class="form-control form-control-sm border-0 bg-light" placeholder="Add guests (email...)">
    </div>

    <!-- Location -->
    <div class="d-flex align-items-center mb-3 px-3">
        <div class="me-3 text-muted"><i class="bi bi-geo-alt fs-5"></i></div>
        <input type="text" id="popover-location" class="form-control form-control-sm border-0 bg-light" placeholder="Add location">
    </div>

    <!-- Description -->
    <div class="d-flex align-items-center mb-3 px-3">
        <div class="me-3 text-muted"><i class="bi bi-justify-left fs-5"></i></div>
        <input type="text" id="popover-description" class="form-control form-control-sm border-0 bg-light" placeholder="Add description">
    </div>

    <!-- Lịch, Màu sắc, Quyền riêng tư, Thông báo -->
    <div class="d-flex align-items-start mb-3 px-3">
        <div class="me-3 mt-1 text-muted"><i class="bi bi-calendar2-event fs-5"></i></div>
        <div class="flex-grow-1">
            <div class="d-flex gap-2 mb-2">
                <!-- Tên các loại lịch (Mock Data) -->
                <select id="popover-calendar-type" class="form-select form-select-sm border-0 bg-light w-auto">
                    <option value="Học thuật">Học thuật</option>
                    <option value="Sinh hoạt CLB">Sinh hoạt CLB</option>
                    <option value="Cá nhân">Cá nhân</option>
                </select>
                <!-- Bảng chọn màu -->
                <input type="color" id="popover-color" class="form-control form-control-color border-0 p-0" value="#039be5" style="width: 30px; height: 30px; cursor: pointer;" title="Choose color">
            </div>
            <div class="d-flex gap-2 mb-2">
                <select class="form-select form-select-sm border-0 bg-light w-auto text-muted">
                    <option>Busy</option>
                    <option>Free</option>
                </select>
                <select id="popover-visibility" class="form-select form-select-sm border-0 bg-light w-auto text-muted">
                    <option value="0">Default visibility</option>
                    <option value="1">Public</option>
                    <option value="2">Private</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm border-0 bg-light w-auto text-muted">
                    <option>30 minutes before</option>
                    <option>10 minutes before</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="d-flex justify-content-end align-items-center mt-2 px-3 pt-2">
        <button class="btn btn-light btn-sm me-2 text-primary fw-bold bg-transparent">More options</button>
        <button id="btn-save-event" class="btn btn-primary px-4 rounded-pill">Save</button>
    </div>
</div>

